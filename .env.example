# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- DockerProxy Configuration ---

# Bootstrap admin credentials. After first start, the platform persists the bootstrap admin in SQLite.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
JWT_SECRET=change-me

# Master key used to encrypt SSH / integration credentials in SQLite.
APP_MASTER_KEY=change-me-too

# Nginx Gateway Container Name (Used for reloading Nginx)
NGINX_CONTAINER_NAME=nginx-gateway

# Cert Agent Container Name (Used for acme.sh operations)
CERT_AGENT_CONTAINER_NAME=cert-agent

# VPS Public IP (Used for Cloudflare DNS A record binding)
VPS_PUBLIC_IP=1.2.3.4

# Cloudflare API Token (Needs Zone.DNS:Edit permissions)
CF_API_TOKEN=

# Cloudflare Zone ID (The Zone ID for your main domain)
CF_ZONE_ID=

# Cloudflare DNS Proxied status (true/false)
CF_PROXIED=true

# Cloudflare DNS TTL (1 = Auto)
CF_TTL=1
